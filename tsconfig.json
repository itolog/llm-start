{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react",
    "paths": {
      "@/*": ["./src/*"],
      "react-devtools-core": ["./src/stubs/react-devtools-core.ts"]
    }
  },
  "include": ["src/**/*"]
}
