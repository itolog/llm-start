{
  "name": "lang-app",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.tsx",
  "scripts": {
    "start": "bun src/index.tsx",
    "dev": "bun --watch src/index.tsx",
    "build": "bun build src/index.tsx --compile --minify --outfile dist/lang-app",
    "lint": "conc --timings -c \"auto\" \"bun:lint:*\"",
    "lint:code": "eslint .",
    "lint:types": "tsc --noEmit",
    "lint:format": "prettier --check .",
    "fix:lint": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "conc --timings -c \"auto\" \"bun run lint\" \"bun run test\"",
    "audit": "bun audit",
    "deps:update": "bun update -i"
  },
  "dependencies": {
    "@langchain/core": "1.1.48",
    "@langchain/ollama": "1.2.7",
    "ink": "7.0.5",
    "ink-spinner": "5.0.0",
    "ink-text-input": "6.0.0",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "concurrently": "10.0.3",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itolog/llm-start.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/itolog/llm-start/issues"
  },
  "homepage": "https://github.com/itolog/llm-start#readme"
}
