{
  "name": "lang-app",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.tsx",
  "scripts": {
    "start": "bun src/index.tsx",
    "dev": "bun --watch src/index.tsx",
    "build": "bun build src/index.tsx --compile --minify --outfile dist/lang-app",
    "lint": "conc --timings -c \"auto\" \"bun:lint:*\"",
    "lint:code": "oxlint",
    "lint:types": "tsc --noEmit",
    "lint:format": "oxfmt --check .",
    "fix:lint": "oxlint --fix",
    "format": "oxfmt --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "conc --timings -c \"auto\" \"bun run lint\" \"bun run test\"",
    "deps:audit": "bun audit",
    "deps:update": "bun update -i",
    "deps:reinstall": "rm -rf node_modules bun.lock && bun install",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@langchain/core": "1.2.1",
    "@langchain/ollama": "1.3.0",
    "ink": "7.1.0",
    "ink-spinner": "5.0.0",
    "ink-text-input": "6.0.0",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@vitest/coverage-v8": "4.1.9",
    "concurrently": "10.0.3",
    "happy-dom": "20.10.6",
    "lefthook": "2.1.9",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itolog/llm-start.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/itolog/llm-start/issues"
  },
  "homepage": "https://github.com/itolog/llm-start#readme"
}
