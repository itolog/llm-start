{
  "name": "lang-app",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "homepage": "https://github.com/itolog/llm-start#readme",
  "bugs": {
    "url": "https://github.com/itolog/llm-start/issues"
  },
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itolog/llm-start.git"
  },
  "type": "module",
  "main": "src/index.tsx",
  "scripts": {
    "start": "bun src/index.tsx",
    "start:deps-graph": "skott src/index.tsx --tsconfig=tsconfig.json --no-trackTypeOnlyDependencies",
    "dev": "bun --watch src/index.tsx",
    "build": "bun build src/index.tsx --compile --minify --outfile dist/lang-app",
    "lint": "conc --timings -c \"auto\" \"bun:lint:*\"",
    "lint:code": "oxlint",
    "lint:types": "tsc --noEmit",
    "lint:unused": "knip",
    "lint:format": "oxfmt --check .",
    "fix:lint": "oxlint --fix",
    "format": "oxfmt --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "conc --timings -c \"auto\" \"bun run lint\" \"bun run test\"",
    "deps:audit": "bun audit",
    "deps:update": "bun update -i",
    "deps:reinstall": "rm -rf node_modules bun.lock && bun install",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@langchain/core": "1.2.1",
    "@langchain/ollama": "1.3.0",
    "ink": "7.1.0",
    "ink-big-text": "2.0.0",
    "ink-gradient": "4.0.1",
    "ink-select-input": "6.2.0",
    "ink-spinner": "5.0.0",
    "ink-text-input": "6.0.0",
    "react": "19.2.7",
    "ts-pattern": "5.9.0"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@vitest/coverage-v8": "4.1.10",
    "concurrently": "10.0.3",
    "happy-dom": "20.10.6",
    "knip": "6.25.0",
    "lefthook": "2.1.9",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "skott": "0.35.11",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "engines": {
    "bun": "1.3.14"
  },
  "packageManager": "bun@1.3.14"
}
