{
  "trailingComma": "all",
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "bracketSpacing": true,
  "endOfLine": "lf",
  "singleQuote": false,
  "jsxSingleQuote": false,
  "bracketSameLine": true,
  "arrowParens": "always",
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": ["dist", "node_modules", ".claude", "**/*.md"]
}
